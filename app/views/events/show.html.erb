<div class="watch-page">
  <% if @preview_mode %>
    <div class="preview-banner">
      <i class="bi bi-eye"></i>
      Preview Mode - This event is not publicly visible
    </div>
  <% end %>
  <div class="watch-page-container">
    <%# Video Player Section %>
    <div class="watch-video-section">
      <% case @event.status %>
      <% when 'upcoming' %>
        <% if @preview_mode && (@event.live_embed_code.present? || @event.mux_live_playback_id.present?) %>
          <div class="watch-video-player">
            <% if @event.live_embed_code.present? %>
              <%= @event.live_embed_code.html_safe %>
            <% elsif @event.mux_live_playback_id.present? %>
              <%= mux_player(playback_id: @event.mux_live_playback_id, title: @event.title, video_id: @event.slug, live: true) %>
            <% end %>
          </div>
        <% else %>
          <div class="watch-video-placeholder">
            <p>This stream will begin <%= @event.event_date.strftime('%A, %B %-d') %> at <%= @event.start_at&.in_time_zone(@event.time_zone)&.strftime('%-I:%M %p %Z') || 'TBD' %></p>
          </div>
        <% end %>

      <% when 'live' %>
        <div class="watch-video-player">
          <% if @event.live_embed_code.present? %>
            <%= @event.live_embed_code.html_safe %>
          <% elsif @event.mux_live_playback_id.present? %>
            <%= mux_player(playback_id: @event.mux_live_playback_id, title: @event.title, video_id: @event.slug, live: true) %>
          <% end %>
        </div>

      <% when 'ended' %>
        <div class="watch-video-placeholder">
          <i class="bi bi-stop-circle"></i>
          <p>This broadcast has concluded</p>
        </div>

      <% when 'replay_pending' %>
        <div class="watch-video-placeholder">
          <i class="bi bi-clock-history"></i>
          <p>A replay of this broadcast will be available shortly</p>
        </div>

      <% when 'replay_available' %>
        <div class="watch-video-player">
          <% if @event.replay_embed_code.present? %>
            <%= @event.replay_embed_code.html_safe %>
          <% elsif @event.mux_replay_playback_id.present? %>
            <%= mux_player(playback_id: @event.mux_replay_playback_id, title: @event.title, video_id: @event.slug, start_time: @event.replay_start_time, end_time: @event.replay_end_time) %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Event Information Section %>
    <div class="watch-event-info">
      <%# Event Title %>
      <h1 class="watch-event-title"><%= @event.title %></h1>

      <%# Status Badge and Sport Line %>
      <div class="watch-event-meta">
        <% if @event.live? %>
          <span class="watch-live-badge">LIVE</span>
        <% elsif @event.replay_available? %>
          <span class="watch-replay-badge">REPLAY</span>
        <% end %>
        <% if @event.sport.present? %>
          <span class="watch-sport-info">
            <%= @event.sport_emoji %>
            <strong><%= @event.sport %></strong>
            <% if @event.round.present? %>
              <span class="watch-separator">•</span>
              <%= @event.round %>
            <% end %>
          </span>
        <% end %>
      </div>

      <%# Event Details Card %>
      <div class="watch-details-card">
        <div class="watch-details-grid">
          <div class="watch-detail-item">
            <div class="watch-detail-label">Date & Time</div>
            <div class="watch-detail-value">
              <%= @event.event_date.strftime('%A, %B %-d') %> at <%= @event.start_at&.in_time_zone(@event.time_zone)&.strftime('%-I:%M %p %Z') || 'TBD' %>
            </div>
          </div>

          <% if @event.location.present? %>
            <div class="watch-detail-item">
              <div class="watch-detail-label">Location</div>
              <div class="watch-detail-value"><%= @event.location %></div>
            </div>
          <% end %>

          <% if @event.teams.any? %>
            <div class="watch-detail-item">
              <div class="watch-detail-label">Teams</div>
              <div class="watch-detail-value">
                <div class="watch-teams-list">
                  <% @event.teams.each do |team| %>
                    <%= team_chip(team) %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <% if @event.description.present? %>
          <div class="watch-detail-description">
            <%= simple_format(@event.description) %>
          </div>
        <% end %>
      </div>

      <%# Related Broadcasts %>
      <% if @event.related_events.any? %>
        <div class="watch-related-games">
          <h2 class="watch-related-games-title">Related Broadcasts</h2>
          <div class="watch-related-games-list">
            <% @event.related_events.each do |event| %>
              <%= link_to event_path(event.slug), class: "watch-related-game-card watch-related-game-card--#{event.status}" do %>
                <div class="watch-related-game-sport">
                  <% if event.sport.present? %>
                    <span class="watch-related-game-emoji"><%= event.sport_emoji %></span>
                    <span class="watch-related-game-sport-name"><%= event.sport %></span>
                  <% end %>
                  <% if event.round.present? %>
                    <span class="watch-related-game-round"><%= event.round %></span>
                  <% end %>
                  <% if event.live? %>
                    <span class="event-card-badge event-card-badge--live">Live</span>
                  <% elsif event.replay_available? %>
                    <span class="event-card-badge event-card-badge--replay">Replay</span>
                  <% elsif event.replay_pending? %>
                    <span class="event-card-badge event-card-badge--pending">Replay Pending</span>
                  <% end %>
                </div>
                <div class="watch-related-game-title"><%= event.title %></div>
                <div class="watch-related-game-meta">
                  <%= event.event_date.strftime('%A, %B %-d') %>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% if @event.upcoming? || @event.live? || @event.replay_pending? || @event.replay_available? %>
  <script type="module">
    import { initializePolling } from 'polling';

    initializePolling({
      eventSlug: '<%= @event.slug %>',
      eventId: '<%= @event.id %>',
      eventStatus: '<%= @event.replay_available? ? "vod" : @event.status %>',
      forceReloadVersion: <%= @event.force_reload_count %>,
      sessionId: '<%= Current.session.id %>',
      enabled: <%= @event.live? || @event.replay_available? %>,
      initialTtl: <%= Dacsports.redis.get('event_status_ttl').to_i %>
    });
  </script>
<% end %>
