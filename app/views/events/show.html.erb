<div class="watch-page">
  <div class="watch-page-container">
    <%# Video Player Section %>
    <div class="watch-video-section">
      <% case @event.status %>
      <% when 'upcoming' %>
        <div class="watch-video-placeholder">
          <p>Stream will begin at scheduled time</p>
        </div>

      <% when 'live' %>
        <div class="watch-video-player">
          <%= @event.live_embed_code.html_safe %>
        </div>

      <% when 'ended' %>
        <div class="watch-video-placeholder">
          <i class="bi bi-stop-circle"></i>
          <p>Event has concluded</p>
        </div>

      <% when 'replay_pending' %>
        <div class="watch-video-placeholder">
          <i class="bi bi-clock-history"></i>
          <p>Replay will be available shortly</p>
        </div>

      <% when 'vod' %>
        <div class="watch-video-player">
          <%= @event.replay_embed_code.html_safe %>
        </div>
      <% end %>
    </div>

    <%# Event Information Section %>
    <div class="watch-event-info">
      <%# Event Title %>
      <h1 class="watch-event-title"><%= @event.title %></h1>

      <%# Status Badge and Sport Line %>
      <div class="watch-event-meta">
        <% if @event.live? %>
          <span class="watch-live-badge">LIVE</span>
        <% elsif @event.vod? %>
          <span class="watch-replay-badge">REPLAY</span>
        <% end %>
        <% if @event.sport.present? %>
          <span class="watch-sport-info">
            <%= @event.sport_emoji %>
            <strong><%= @event.sport %></strong>
            <% if @event.subtitle.present? %>
              <span class="watch-separator">•</span>
              <%= @event.subtitle %>
            <% end %>
          </span>
        <% end %>
      </div>

      <%# Event Details Card %>
      <div class="watch-details-card">
        <div class="watch-details-grid">
          <div class="watch-detail-item">
            <div class="watch-detail-label">Date & Time</div>
            <div class="watch-detail-value">
              <%= @event.event_date.strftime('%B %-d, %Y') %> at <%= @event.start_at&.in_time_zone(@event.time_zone)&.strftime('%I:%M %p %Z') || 'TBD' %>
            </div>
          </div>

          <% if @event.location.present? %>
            <div class="watch-detail-item">
              <div class="watch-detail-label">Location</div>
              <div class="watch-detail-value"><%= @event.location %></div>
            </div>
          <% end %>
        </div>
      </div>

      <%# Description %>
      <% if @event.description.present? %>
        <div class="watch-event-description">
          <%= simple_format(@event.description) %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% if @event.live? || @event.vod? %>
  <script type="module">
    import { initializePolling } from 'polling';

    initializePolling({
      eventSlug: '<%= @event.slug %>',
      eventId: '<%= @event.id %>',
      eventStatus: '<%= @event.status %>',
      forceReloadVersion: <%= @event.force_reload_count %>,
      sessionId: '<%= Current.session.id %>'
    });
  </script>
<% end %>
