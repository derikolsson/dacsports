<div class="container py-5">
  <div class="text-center mb-5">
    <h1 class="display-4 fw-bold">Live Streaming Schedule</h1>
  </div>

  <div class="table-responsive">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Date</th>
          <th>Time (CT)</th>
          <th>Event</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <%# Live events first %>
        <% @live_events.each do |event| %>
          <tr class="table-success">
            <td><%= event.event_date.strftime('%A, %B %-d') %></td>
            <td><%= event.start_at&.in_time_zone(event.time_zone)&.strftime('%I:%M %p') || 'TBD' %></td>
            <td>
              <strong><%= event.title %></strong>
              <% if event.subtitle.present? %>
                <br><small class="text-muted"><%= event.subtitle %></small>
              <% end %>
            </td>
            <td>
              <%= link_to 'Watch Now', event_path(event), class: 'btn btn-primary btn-sm' %>
            </td>
          </tr>
        <% end %>

        <%# Upcoming events %>
        <% @upcoming_events.each do |event| %>
          <tr>
            <td><%= event.event_date.strftime('%A, %B %-d') %></td>
            <td><%= event.start_at&.in_time_zone(event.time_zone)&.strftime('%I:%M %p') || 'TBD' %></td>
            <td>
              <%= event.title %>
              <% if event.subtitle.present? %>
                <br><small class="text-muted"><%= event.subtitle %></small>
              <% end %>
            </td>
            <td><span class="text-muted">Upcoming</span></td>
          </tr>
        <% end %>

        <%# Past events %>
        <% @past_events.each do |event| %>
          <tr>
            <td><%= event.event_date.strftime('%A, %B %-d') %></td>
            <td><%= event.start_at&.in_time_zone(event.time_zone)&.strftime('%I:%M %p') || 'TBD' %></td>
            <td>
              <%= event.title %>
              <% if event.subtitle.present? %>
                <br><small class="text-muted"><%= event.subtitle %></small>
              <% end %>
            </td>
            <td>
              <% if event.vod? %>
                <%= link_to 'Watch Replay', event_path(event), class: 'btn btn-outline-primary btn-sm' %>
              <% elsif event.ended? %>
                <span class="text-muted">Event Ended</span>
              <% elsif event.replay_pending? %>
                <span class="text-muted">Replay Pending</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
