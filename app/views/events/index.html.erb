<div class="container pt-3 pb-5">
  <div class="text-center mb-5">
    <h1 class="display-4 fw-bold mb-2">DAC Sports Network</h1>
    <p class="lead text-muted">Your home for live broadcasts of Dallas College athletics</p>
  </div>

  <div class="table-responsive">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Event</th>
          <th>Date</th>
          <th>Time (CT)</th>
          <th>Location</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @events.each do |event| %>
          <tr class="<%= 'event-row--live' if event.live? %>">
            <td>
              <strong class="event-name"><%= link_to event.title, event_path(event.slug), class: 'text-decoration-none' %></strong>
              <div class="mt-1">
                <% if event.sport.present? %>
                  <small class="fw-semibold text-dark">
                    <%= event.sport_emoji %>
                    <%= event.sport %>
                  </small>
                <% end %>
                <% if event.sport.present? && event.round.present? %>
                  <small class="text-muted mx-2">•</small>
                <% end %>
                <% if event.round.present? %>
                  <small class="text-muted"><%= event.round %></small>
                <% end %>
              </div>
            </td>
            <td class="meta-text"><%= event.event_date.strftime('%A, %B %-d') %></td>
            <td class="meta-text"><%= event.start_at&.in_time_zone('America/Chicago')&.strftime('%-I:%M %p') || 'TBD' %></td>
            <td class="meta-text"><%= event.location || 'TBD' %></td>
            <td>
              <% if event.live? %>
                <%= link_to event_path(event.slug), class: 'badge-live text-decoration-none' do %>
                  LIVE
                <% end %>
              <% elsif event.upcoming? %>
                <span class="badge-upcoming">UPCOMING</span>
              <% elsif event.replay_available? %>
                <%= link_to event_path(event.slug), class: 'badge-replay text-decoration-none' do %>
                  REPLAY
                <% end %>
              <% elsif event.ended? %>
                <span class="text-muted">Event Ended</span>
              <% elsif event.replay_pending? %>
                <span class="text-muted">Replay Pending</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
</div>
