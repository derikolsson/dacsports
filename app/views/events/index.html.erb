<div class="container py-5">
  <h1 class="mb-4">Broadcast Schedule</h1>

  <div class="table-responsive">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Event</th>
          <th>Date</th>
          <th>Time (CT)</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <%# Live events first %>
        <% @live_events.each do |event| %>
          <tr class="event-row--live">
            <td>
              <div>
                <% if event.sport.present? %>
                  <span class="sport-badge sport-badge--<%= event.sport.downcase %>">
                    <%= event.sport_emoji %>
                    <%= event.sport %>
                  </span>
                <% end %>
                <strong class="event-name"><%= link_to event.title, event_path(event), class: 'text-decoration-none' %></strong>
              </div>
              <% if event.subtitle.present? %>
                <small class="text-muted d-block mt-1"><%= event.subtitle %></small>
              <% end %>
            </td>
            <td class="meta-text"><%= event.event_date.strftime('%A, %B %-d') %></td>
            <td class="meta-text"><%= event.start_at&.in_time_zone(event.time_zone)&.strftime('%I:%M %p') || 'TBD' %></td>
            <td>
              <%= link_to event_path(event), class: 'btn btn-live text-decoration-none' do %>
                🔴 LIVE
              <% end %>
            </td>
          </tr>
        <% end %>

        <%# Upcoming events %>
        <% @upcoming_events.each do |event| %>
          <tr>
            <td>
              <div>
                <% if event.sport.present? %>
                  <span class="sport-badge sport-badge--<%= event.sport.downcase %>">
                    <%= event.sport_emoji %>
                    <%= event.sport %>
                  </span>
                <% end %>
                <strong class="event-name"><%= link_to event.title, event_path(event), class: 'text-decoration-none' %></strong>
              </div>
              <% if event.subtitle.present? %>
                <small class="text-muted d-block mt-1"><%= event.subtitle %></small>
              <% end %>
            </td>
            <td class="meta-text"><%= event.event_date.strftime('%A, %B %-d') %></td>
            <td class="meta-text"><%= event.start_at&.in_time_zone(event.time_zone)&.strftime('%I:%M %p') || 'TBD' %></td>
            <td>
              <span class="btn btn-upcoming">UPCOMING</span>
            </td>
          </tr>
        <% end %>

        <%# Past events %>
        <% @past_events.each do |event| %>
          <tr>
            <td>
              <div>
                <% if event.sport.present? %>
                  <span class="sport-badge sport-badge--<%= event.sport.downcase %>">
                    <%= event.sport_emoji %>
                    <%= event.sport %>
                  </span>
                <% end %>
                <strong class="event-name"><%= link_to event.title, event_path(event), class: 'text-decoration-none' %></strong>
              </div>
              <% if event.subtitle.present? %>
                <small class="text-muted d-block mt-1"><%= event.subtitle %></small>
              <% end %>
            </td>
            <td class="meta-text"><%= event.event_date.strftime('%A, %B %-d') %></td>
            <td class="meta-text"><%= event.start_at&.in_time_zone(event.time_zone)&.strftime('%I:%M %p') || 'TBD' %></td>
            <td>
              <% if event.vod? %>
                <%= link_to event_path(event), class: 'btn btn-replay text-decoration-none' do %>
                  WATCH REPLAY
                <% end %>
              <% elsif event.ended? %>
                <span class="text-muted">Event Ended</span>
              <% elsif event.replay_pending? %>
                <span class="text-muted">Replay Pending</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
</div>
