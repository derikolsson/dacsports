<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Events</h1>
  <%= link_to 'New Event', new_internal_event_path, class: 'btn btn-primary' %>
</div>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Date</th>
      <th>Title</th>
      <th>Sport</th>
      <th>Status</th>
      <th>Slug</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @events.each do |event| %>
      <tr>
        <td><%= event.event_date.strftime('%Y-%m-%d') %></td>
        <td>
          <%= event.title %>
          <% if event.round.present? %>
            <br><small class="text-muted"><%= event.round %></small>
          <% end %>
        </td>
        <td>
          <% if event.sport.present? %>
            <%= event.sport_emoji %>
            <%= event.sport %>
          <% else %>
            <span class="text-muted">—</span>
          <% end %>
        </td>
        <td>
          <span class="badge bg-<%= case event.status
            when 'upcoming' then 'secondary'
            when 'live' then 'success'
            when 'ended' then 'dark'
            when 'replay_pending' then 'warning'
            when 'vod' then 'primary'
          end %>">
            <%= event.status.titleize %>
          </span>
        </td>
        <td><code><%= event.slug %></code></td>
        <td>
          <div class="d-flex gap-2">
            <%= link_to 'Edit', edit_internal_event_path(event), class: 'btn btn-sm btn-secondary' %>

            <% if event.can_go_live? %>
              <%= button_to 'Go Live', go_live_internal_event_path(event),
                  method: :post, class: 'btn btn-sm btn-success',
                  data: { confirm: 'Start this event now?' } %>
            <% end %>

            <% if event.can_end? %>
              <%= button_to 'End Event', end_event_internal_event_path(event),
                  method: :post, class: 'btn btn-sm btn-dark',
                  data: { confirm: 'End this event (no replay)?' } %>
            <% end %>

            <% if event.can_mark_replay_pending? %>
              <%= button_to 'Mark Replay Pending', mark_replay_pending_internal_event_path(event),
                  method: :post, class: 'btn btn-sm btn-warning',
                  data: { confirm: 'Mark this event for replay?' } %>
            <% end %>

            <% if event.can_publish_replay? %>
              <%= button_to 'Publish Replay', publish_replay_internal_event_path(event),
                  method: :post, class: 'btn btn-sm btn-primary',
                  data: { confirm: 'Make replay available?' } %>
            <% end %>

            <%= button_to 'Delete', internal_event_path(event),
                method: :delete, class: 'btn btn-sm btn-danger',
                data: { confirm: 'Are you sure?' } %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
