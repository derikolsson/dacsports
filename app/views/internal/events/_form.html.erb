<%= form_with(model: [:internal, @event]) do |f| %>
  <% if @event.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(@event.errors.count, "error") %> prohibited this event from being saved:</h4>
      <ul>
        <% @event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, class: 'form-label' %>
    <%= f.text_field :title, class: 'form-control', required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :slug, class: 'form-label' %>
    <%= f.text_field :slug, class: 'form-control', required: true, pattern: '[a-z0-9\-]+', placeholder: 'example-slug-here' %>
    <small class="form-text text-muted">URL-friendly slug (lowercase letters, numbers, and hyphens only)</small>
  </div>

  <div class="mb-3">
    <%= f.label :sport, class: 'form-label' %>
    <%= f.select :sport, Event::SPORTS, { include_blank: 'Select a sport' }, class: 'form-select' %>
    <small class="form-text text-muted">Sport type for badge display</small>
  </div>

  <div class="mb-3">
    <%= f.label :location, class: 'form-label' %>
    <%= f.text_field :location, class: 'form-control' %>
    <small class="form-text text-muted">Event location (e.g., "Main Arena", "Home Field")</small>
  </div>

  <div class="mb-3">
    <%= f.label :round, class: 'form-label' %>
    <%= f.text_field :round, class: 'form-control' %>
    <small class="form-text text-muted">Optional round identifier (e.g., "Quarterfinal", "Semifinal", "Championship")</small>
  </div>

  <fieldset class="border rounded p-3 mb-3">
    <legend class="float-none w-auto px-2 fs-6">Teams</legend>
    <% 2.times do |i| %>
      <% event_team = @event.event_teams[i] || @event.event_teams.build %>
      <%= f.fields_for :event_teams, event_team, child_index: i do |et| %>
        <div class="mb-2">
          <%= et.label :team_id, "Team #{i + 1}", class: 'form-label' %>
          <%= et.collection_select :team_id, Team.alphabetical, :id, :name,
              { include_blank: 'Select team' }, class: 'form-select' %>
        </div>
      <% end %>
    <% end %>
    <small class="form-text text-muted">Optional: Associate teams with this event for filtering</small>
  </fieldset>

  <div class="row">
    <div class="col-md-4 mb-3">
      <%= f.label :start_at, "Game Time", class: 'form-label' %>
      <%= f.datetime_local_field :start_at, class: 'form-control', required: true %>
      <small class="form-text text-muted">When the game starts (shown to public)</small>
    </div>

    <div class="col-md-4 mb-3">
      <%= f.label :stream_starts_at, "Stream Start Time", class: 'form-label' %>
      <%= f.datetime_local_field :stream_starts_at, class: 'form-control' %>
      <small class="form-text text-muted">When stream auto-starts (leave blank for manual start)</small>
    </div>

    <div class="col-md-4 mb-3">
      <%= f.label :time_zone, class: 'form-label' %>
      <%= f.hidden_field :time_zone, value: 'Central Time (US & Canada)' %>
      <%= f.text_field :time_zone, value: 'Central Time (US & Canada)', disabled: true, class: 'form-control' %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: 'form-label' %>
    <%= f.text_area :description, rows: 4, class: 'form-control' %>
  </div>

  <fieldset class="border rounded p-3 mb-3">
    <legend class="float-none w-auto px-2 fs-6">Live Stream</legend>
    <div class="mb-3">
      <%= f.label :mux_live_playback_id, "Mux Playback ID", class: 'form-label' %>
      <%= f.text_field :mux_live_playback_id, class: 'form-control', placeholder: 'e.g. DS00Spx1CV902MCtPj5WknGlR102V5HFkDe' %>
    </div>
    <div class="mb-0">
      <%= f.label :live_embed_code, "Custom Embed Code (HTML)", class: 'form-label' %>
      <%= f.text_area :live_embed_code, rows: 3, class: 'form-control' %>
      <small class="form-text text-muted">Use for non-Mux sources. Takes precedence over Mux playback ID.</small>
    </div>
  </fieldset>

  <fieldset class="border rounded p-3 mb-3">
    <legend class="float-none w-auto px-2 fs-6">Replay</legend>
    <div class="mb-3">
      <%= f.label :mux_replay_playback_id, "Mux Playback ID", class: 'form-label' %>
      <%= f.text_field :mux_replay_playback_id, class: 'form-control', placeholder: 'e.g. DS00Spx1CV902MCtPj5WknGlR102V5HFkDe' %>
    </div>
    <div class="row mb-3">
      <div class="col-md-6">
        <%= f.label :replay_start_time, "Start Time (seconds)", class: 'form-label' %>
        <%= f.number_field :replay_start_time, class: 'form-control', min: 0, step: 0.01, placeholder: '0' %>
        <small class="form-text text-muted">Clip start point in seconds</small>
      </div>
      <div class="col-md-6">
        <%= f.label :replay_end_time, "End Time (seconds)", class: 'form-label' %>
        <%= f.number_field :replay_end_time, class: 'form-control', min: 0, step: 0.01, placeholder: 'Leave blank for full video' %>
        <small class="form-text text-muted">Clip end point in seconds</small>
      </div>
    </div>
    <div class="mb-0">
      <%= f.label :replay_embed_code, "Custom Embed Code (HTML)", class: 'form-label' %>
      <%= f.text_area :replay_embed_code, rows: 3, class: 'form-control' %>
      <small class="form-text text-muted">Use for non-Mux sources. Takes precedence over Mux playback ID.</small>
    </div>
  </fieldset>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :status, class: 'form-label' %>
      <%= f.select :status, Event.statuses.keys.map { |s| [s.titleize, s] }, {}, class: 'form-select' %>
    </div>
  </div>

  <div class="mb-3">
    <div class="form-check form-switch">
      <%= f.check_box :visible, class: 'form-check-input', role: 'switch' %>
      <%= f.label :visible, "Visible to public", class: 'form-check-label' %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.submit class: 'btn btn-primary' %>
    <%= link_to 'Cancel', internal_events_path, class: 'btn btn-secondary' %>
  </div>
<% end %>
