<%= form_with(model: [:internal, @event]) do |f| %>
  <% if @event.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(@event.errors.count, "error") %> prohibited this event from being saved:</h4>
      <ul>
        <% @event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, class: 'form-label' %>
    <%= f.text_field :title, class: 'form-control', required: true %>
    <small class="form-text text-muted">Slug will be auto-generated from title</small>
  </div>

  <div class="mb-3">
    <%= f.label :sport, class: 'form-label' %>
    <%= f.select :sport, Event::SPORTS, { include_blank: 'Select a sport' }, class: 'form-select' %>
    <small class="form-text text-muted">Sport type for badge display</small>
  </div>

  <div class="mb-3">
    <%= f.label :location, class: 'form-label' %>
    <%= f.text_field :location, class: 'form-control' %>
    <small class="form-text text-muted">Event location (e.g., "Main Arena", "Home Field")</small>
  </div>

  <div class="mb-3">
    <%= f.label :round, class: 'form-label' %>
    <%= f.text_field :round, class: 'form-control' %>
    <small class="form-text text-muted">Optional round identifier (e.g., "Quarterfinal", "Semifinal", "Championship")</small>
  </div>

  <div class="row">
    <div class="col-md-8 mb-3">
      <%= f.label :start_at, "Event Date & Time", class: 'form-label' %>
      <%= f.datetime_local_field :start_at, class: 'form-control', required: true %>
      <small class="form-text text-muted">Event start time (for auto-start via cron job)</small>
    </div>

    <div class="col-md-4 mb-3">
      <%= f.label :time_zone, class: 'form-label' %>
      <%= f.time_zone_select :time_zone, ActiveSupport::TimeZone.us_zones, { default: 'Central Time (US & Canada)' }, class: 'form-select' %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: 'form-label' %>
    <%= f.text_area :description, rows: 4, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :live_embed_code, "Live Embed Code (HTML)", class: 'form-label' %>
    <%= f.text_area :live_embed_code, rows: 4, class: 'form-control' %>
  </div>

  <div class="mb-3">
    <%= f.label :replay_embed_code, "Replay Embed Code (HTML)", class: 'form-label' %>
    <%= f.text_area :replay_embed_code, rows: 4, class: 'form-control' %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :status, class: 'form-label' %>
      <%= f.select :status, Event.statuses.keys.map { |s| [s.titleize, s] }, {}, class: 'form-select' %>
    </div>
  </div>

  <div class="mb-3">
    <div class="form-check form-switch">
      <%= f.check_box :visible, class: 'form-check-input', role: 'switch' %>
      <%= f.label :visible, "Visible to public", class: 'form-check-label' %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.submit class: 'btn btn-primary' %>
    <%= link_to 'Cancel', internal_events_path, class: 'btn btn-secondary' %>
  </div>
<% end %>
