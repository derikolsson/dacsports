<table class="table table-striped">
  <thead>
    <tr>
      <th>Date & Time</th>
      <th>Event</th>
      <th>Teams</th>
      <th>Status</th>
      <th>Visibility</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% events.each do |event| %>
      <tr>
        <td>
          <div><strong><%= event.event_date.strftime('%Y-%m-%d') %></strong></div>
          <small>
            <strong><%= event.start_at&.in_time_zone(event.time_zone)&.strftime('%-I:%M %p') || 'TBD' %></strong>
          </small>
          <% if event.stream_starts_at.present? %>
            <br>
            <small class="text-muted">
              Stream: <%= event.stream_starts_at.in_time_zone(event.time_zone).strftime('%-I:%M %p') %>
            </small>
          <% end %>
        </td>
        <td>
          <div><strong><%= event.title %></strong></div>
          <small class="text-muted d-block">
            <code><%= event.slug %></code>
          </small>
          <% metadata = [[event.sport_emoji, event.sport].compact_blank.join(' '), event.round].compact_blank %>
          <% if metadata.any? %>
            <small class="text-muted"><%= metadata.join(' · ') %></small>
          <% end %>
        </td>
        <td>
          <% if event.event_teams.any? %>
            <% event.event_teams.each do |et| %>
              <div class="d-flex align-items-center gap-2 mb-1">
                <%= team_badge(et.team) %>
                <span><%= et.team.name %></span>
              </div>
            <% end %>
          <% else %>
            <span class="text-muted">—</span>
          <% end %>
        </td>
        <td>
          <span class="badge bg-<%= case event.status
            when 'upcoming' then 'secondary'
            when 'live' then 'success'
            when 'ended' then 'dark'
            when 'replay_pending' then 'warning'
            when 'replay_available' then 'primary'
            when 'technical_difficulties' then 'danger'
          end %>">
            <%= event.status.titleize %>
          </span>
        </td>
        <td class="text-center">
          <% if event.visible %>
            <span class="text-success" title="Visible to public">✓</span>
          <% else %>
            <span class="text-danger" title="Hidden from public">✗</span>
          <% end %>
        </td>
        <td>
          <div class="d-flex gap-2">
            <%= link_to 'Edit', edit_internal_event_path(event), class: 'btn btn-sm btn-secondary' %>

            <div class="dropdown">
              <button class="btn btn-sm btn-outline-dark dropdown-toggle" type="button" data-bs-toggle="dropdown">
                Actions
              </button>
              <ul class="dropdown-menu">
                <li>
                  <%= link_to 'View Public Page', event_path(event.slug), class: 'dropdown-item', target: '_blank' %>
                </li>
                <li>
                  <%= link_to 'Preview Page', event_path(event.slug, preview: true), class: 'dropdown-item', target: '_blank' %>
                </li>

                <% if event.can_go_live? || event.can_end? || event.can_mark_replay_pending? || event.can_mark_technical_difficulties? || event.can_publish_replay? %>
                  <li><hr class="dropdown-divider"></li>
                  <li><h6 class="dropdown-header">Status Changes</h6></li>
                <% end %>

                <% if event.can_go_live? %>
                  <li>
                    <%= button_to 'Go Live', go_live_internal_event_path(event),
                        method: :post, class: 'dropdown-item text-success',
                        data: { confirm: 'Start this event now?' },
                        form: { style: 'display: inline;' } %>
                  </li>
                <% end %>

                <% if event.can_end? %>
                  <li>
                    <%= button_to 'End Event', end_event_internal_event_path(event),
                        method: :post, class: 'dropdown-item',
                        data: { confirm: 'End this event (no replay)?' },
                        form: { style: 'display: inline;' } %>
                  </li>
                <% end %>

                <% if event.can_mark_replay_pending? %>
                  <li>
                    <%= button_to 'Mark Replay Pending', mark_replay_pending_internal_event_path(event),
                        method: :post, class: 'dropdown-item text-warning',
                        data: { confirm: 'Mark this event for replay?' },
                        form: { style: 'display: inline;' } %>
                  </li>
                <% end %>

                <% if event.can_mark_technical_difficulties? %>
                  <li>
                    <%= button_to 'Technical Difficulties', mark_technical_difficulties_internal_event_path(event),
                        method: :post, class: 'dropdown-item text-danger',
                        data: { confirm: 'Mark this event as having technical difficulties?' },
                        form: { style: 'display: inline;' } %>
                  </li>
                <% end %>

                <% if event.can_publish_replay? %>
                  <li>
                    <%= button_to 'Publish Replay', publish_replay_internal_event_path(event),
                        method: :post, class: 'dropdown-item text-primary',
                        data: { confirm: 'Make replay available?' },
                        form: { style: 'display: inline;' } %>
                  </li>
                <% end %>

                <li><hr class="dropdown-divider"></li>
                <li>
                  <%= button_to 'Delete', internal_event_path(event),
                      method: :delete, class: 'dropdown-item text-danger',
                      data: { confirm: 'Are you sure? This cannot be undone.' },
                      form: { style: 'display: inline;' } %>
                </li>
              </ul>
            </div>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
