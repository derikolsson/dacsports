<!DOCTYPE html>
<html>
  <head>
    <title><%= @title ? "#{@title} - DAC Sports Network" : "DAC Sports Network" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="DAC Sports Network live streaming platform - Watch live games and replays from the Dallas Athletic Conference">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <!-- OpenGraph -->
    <meta property="og:title" content="<%= @title || 'DAC Sports Network' %>">
    <meta property="og:description" content="Watch live games and replays from the Dallas Athletic Conference">
    <meta property="og:type" content="website">

    <!-- Favicon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <!-- Session ID for polling -->
    <meta name="session-id" content="<%= Current.session&.id %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">

    <% if Rails.application.credentials.fathom_site_id.present? %>
      <script src="https://cdn.usefathom.com/script.js"
              data-site="<%= Rails.application.credentials.fathom_site_id %>"
              defer></script>
    <% end %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="watch-layout">
    <nav class="navbar navbar-expand-lg navbar-dark dac-navbar">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand" do %>
          <%= image_tag "logo.png", alt: "DAC Sports Network", class: "navbar-logo" %>
          <span class="navbar-brand-text">DAC Sports Network</span>
        <% end %>

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#mainNavbar"
                aria-controls="mainNavbar"
                aria-expanded="false"
                aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <%= link_to "Schedule", schedule_path, class: "nav-link#{' active' if controller_name == 'events' && action_name == 'index'}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Archive", archive_path, class: "nav-link#{' active' if action_name == 'archive'}" %>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle<%= ' active' if controller_name == 'teams' %>" href="#" id="teamsDropdown"
                 role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Teams
              </a>
              <ul class="dropdown-menu dropdown-menu-end dac-teams-dropdown" aria-labelledby="teamsDropdown">
                <% Team.alphabetical.each do |team| %>
                  <li>
                    <%= link_to team_path(team.slug), class: "dropdown-item dac-team-dropdown-item" do %>
                      <% if team.logo_exists? %>
                        <%= image_tag team.logo_path, class: "team-dropdown-logo", alt: "" %>
                      <% end %>
                      <span><%= team.name %></span>
                    <% end %>
                  </li>
                <% end %>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <%= link_to "All Teams", teams_path, class: "dropdown-item fw-semibold" %>
                </li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <%= yield %>

    <footer class="mt-auto py-4 text-center">
      <div class="container">
        <div class="footer-team-logos mb-3">
          <% Team.alphabetical.each do |team| %>
            <% if team.logo_exists? %>
              <%= image_tag team.logo_path, alt: team.name, class: "footer-team-logo" %>
            <% end %>
          <% end %>
        </div>
        <p class="mb-0 small">&copy; <%= Time.current.year %> DAC Sports Network. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
