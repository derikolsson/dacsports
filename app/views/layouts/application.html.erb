<!DOCTYPE html>
<html>
  <head>
    <title><%= @title ? "#{@title} - DAC Sports Network" : "DAC Sports Network" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="DAC Sports Network live streaming platform - Watch live games and replays from the Dallas Athletic Conference">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <!-- OpenGraph -->
    <meta property="og:title" content="<%= @title || 'DAC Sports Network' %>">
    <meta property="og:description" content="Watch live games and replays from the Dallas Athletic Conference">
    <meta property="og:type" content="website">

    <!-- Favicon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <!-- Session ID for polling -->
    <meta name="session-id" content="<%= Current.session&.id %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% if Rails.application.credentials.fathom_site_id.present? %>
      <script src="https://cdn.usefathom.com/script.js"
              data-site="<%= Rails.application.credentials.fathom_site_id %>"
              defer></script>
    <% end %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-dark mb-5">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
          <span class="fw-bold">DAC Sports Network</span>
        <% end %>
      </div>
    </nav>

    <%= yield %>

    <footer class="mt-5 py-4 text-center text-muted">
      <div class="container">
        <p class="mb-0">&copy; <%= Time.current.year %> DAC Sports Network. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
