<div class="container pt-5 pb-3">
  <div class="text-center mb-5">
    <% if @team.logo_exists? %>
      <%= image_tag @team.logo_path, alt: @team.name, class: "team-page-logo mb-3" %>
    <% end %>
    <h1 class="display-4 fw-bold mb-2"><%= @team.name %></h1>
  </div>

  <% if @upcoming_events.any? %>
    <h2 class="h4 mb-3">Upcoming Events</h2>
    <div class="mb-5">
      <%= render "events/event_cards", events: @upcoming_events %>
    </div>
  <% end %>

  <% if @past_events.any? %>
    <h2 class="h4 mb-3">Recent Events</h2>
    <%= render "events/event_cards", events: @past_events %>
  <% end %>

  <% if @upcoming_events.empty? && @past_events.empty? %>
    <div class="empty-state">
      <div class="empty-state-icon">
        <i class="bi bi-calendar-x"></i>
      </div>
      <h2 class="empty-state-title">No Events</h2>
      <p class="empty-state-text">No events found for this team yet. Check back soon or browse our full archive.</p>
      <%= link_to "Browse Archive", archive_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
